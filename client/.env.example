# Backend API origin the browser calls.
# Vite only exposes variables prefixed with VITE_.
#
# Local dev (Express on PORT, default 8000):
VITE_API_BASE_URL=http://localhost:8000
#
# Vercel production — set in the Vercel project dashboard (client):
# VITE_API_BASE_URL=https://your-server.vercel.app
#
# Server env must match for CORS + admin cookies (separate Vercel project):
# FRONTEND_BASE_URL=https://your-client.vercel.app
# BACKEND_BASE_URL=https://your-server.vercel.app

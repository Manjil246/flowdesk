# --- Server ---
NODE_ENV=development
PORT=8000

# --- URLs (CORS + links in emails; match your Vite dev server) ---
FRONTEND_BASE_URL=http://localhost:5173
# Use public HTTPS in production (WhatsApp image.link fetches product JPEGs from /products/*).
BACKEND_BASE_URL=http://localhost:8000
# Optional extra origin for CORS
LOCAL_DEVELOPMENT_URL=

# --- MongoDB Atlas ---
# Get connection string from Atlas → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/flowdesk?retryWrites=true&w=majority

# --- Meta WhatsApp Cloud API ---
# App Dashboard → WhatsApp → API Setup
VERIFY_TOKEN=flowdesk_webhook_secret
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
# E.164 business number shown in Meta / same as display_phone_number in webhooks (for outbound DB rows)
WHATSAPP_BUSINESS_PHONE=
# Optional override (default v21.0)
GRAPH_API_VERSION=v21.0
WABA_ID=

# --- OpenAI (bot replies) ---
OPENAI_API_KEY=
# Default gpt-4o-mini (fast, good for short multilingual WhatsApp). Use gpt-5-nano / gpt-5-mini if you prefer GPT-5.
OPENAI_MODEL=gpt-4o-mini
# Only for non–GPT-5 models (default 0.45). GPT-5 ignores custom temperature.
OPENAI_TEMPERATURE=0.45
# Only for non–GPT-5 models — max_tokens (default 512).
OPENAI_MAX_TOKENS=
# GPT-5 / reasoning: reasoning + reply share this cap (default 8192). Raise if replies are empty.
OPENAI_MAX_COMPLETION_TOKENS=
# Default on; set false or 0 to disable auto-replies
BOT_AUTO_REPLY_ENABLED=true
# Optional: max text turns sent as history (default 24, max 40)
BOT_REPLY_HISTORY_LIMIT=
